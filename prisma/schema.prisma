// Prices (price, mrp) are stored as integer paise (₹499.50 → 49950)
// because Prisma's MongoDB connector has no Decimal type and floats
// are unsafe for money. Format at the UI layer only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum EntityStatus {
  ACTIVE
  INACTIVE
}

enum StockStatus {
  IN_STOCK
  LOW
  OUT_OF_STOCK
}

enum CustomerStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  BLOCKED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model Category {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  slug      String       @unique
  image     String?
  sortOrder Int          @default(0)
  status    EntityStatus @default(ACTIVE)
  parentId  String?      @db.ObjectId
  parent    Category?    @relation("SubCategories", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children  Category[]   @relation("SubCategories")
  products  Product[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([status, sortOrder])
}

// Images are embedded in the product document (Mongo-idiomatic:
// they are always loaded and saved together with the product).
type ProductImage {
  url       String
  thumbUrl  String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)
}

model Product {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  categoryId  String         @db.ObjectId
  category    Category       @relation(fields: [categoryId], references: [id])
  name        String
  slug        String         @unique
  sku         String         @unique
  brand       String?
  description String?
  specs       Json?
  price       Int // paise
  mrp         Int? // paise
  moq         Int?
  stockStatus StockStatus    @default(IN_STOCK)
  status      EntityStatus   @default(ACTIVE)
  tags        String[]       @default([])
  images      ProductImage[]
  pageViews   PageView[]
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([categoryId, status])
  @@index([deletedAt])
  // Hot storefront listing: filter {status, deletedAt} sorted by createdAt.
  @@index([status, deletedAt, createdAt])
}

model Customer {
  id           String          @id @default(auto()) @map("_id") @db.ObjectId
  businessName String
  contactName  String
  phone        String          @unique
  passwordHash String
  email        String?
  gstNumber    String?
  city         String?
  status       CustomerStatus  @default(PENDING)
  notes        String?
  accessGrants AccessGrant[]
  requests     AccessRequest[]
  sessions     Session[]
  pageViews    PageView[]
  lastLoginAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([status])
}

model AccessGrant {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  customerId String    @db.ObjectId
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  approvedAt DateTime  @default(now())
  expiresAt  DateTime?
  revokedAt  DateTime?
  grantedBy  String

  @@index([customerId, expiresAt])
}

model AccessRequest {
  id         String        @id @default(auto()) @map("_id") @db.ObjectId
  customerId String        @db.ObjectId
  customer   Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status     RequestStatus @default(PENDING)
  reason     String?
  decidedAt  DateTime?
  createdAt  DateTime      @default(now())

  @@index([status, createdAt])
}

model Admin {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  email        String    @unique
  passwordHash String
  totpSecret   String?
  name         String
  createdAt    DateTime  @default(now())
  sessions     Session[]
}

model Session {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  tokenHash  String    @unique
  customerId String?   @db.ObjectId
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  adminId    String?   @db.ObjectId
  admin      Admin?    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?

  @@index([customerId])
  @@index([adminId])
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  actorType String
  actorId   String
  action    String
  entity    String
  entityId  String
  diff      Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}

model Notification {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  type      String
  payload   Json
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([readAt, createdAt])
}

// Web Push subscriptions (admin devices) — populated when an admin enables
// push in the PWA; consumed by src/server/notify/push.ts to send alerts.
model PushSubscription {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  endpoint  String   @unique
  p256dh    String
  auth      String
  adminId   String?  @db.ObjectId
  userAgent String?
  createdAt DateTime @default(now())

  @@index([adminId])
}

model PageView {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  customerId String?   @db.ObjectId
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  productId  String    @db.ObjectId
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())

  @@index([productId, createdAt])
  @@index([customerId, createdAt])
}
