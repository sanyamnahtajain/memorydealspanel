// Prices (price, mrp) are stored as integer paise (₹499.50 → 49950)
// because Prisma's MongoDB connector has no Decimal type and floats
// are unsafe for money. Format at the UI layer only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum EntityStatus {
  ACTIVE
  INACTIVE
}

enum StockStatus {
  IN_STOCK
  LOW
  OUT_OF_STOCK
}

enum CustomerStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  BLOCKED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PLACED
  CONFIRMED
  PROCESSING
  FULFILLED
  CANCELLED
}

// ── GST / tax (Phase 13) ──────────────────────────────────────────────────
// How a stored price relates to GST. EXCLUSIVE: the stored paise is the
// taxable base and GST is added on top. INCLUSIVE: the stored paise already
// contains GST (MRP-style) and the base is back-computed.
enum TaxTreatment {
  TAX_EXCLUSIVE
  TAX_INCLUSIVE
}

// Intra-state supply → CGST + SGST; inter-state → IGST. Decided server-side
// from the seller's state vs the customer's place of supply.
enum SupplyType {
  INTRA
  INTER
}

// GST rounding policy: per-line (default, standard on invoices) or a single
// invoice-level round-off to the nearest rupee.
enum RoundingMode {
  LINE
  INVOICE
}

// How prices are shown to retailers by default (independent of storage).
enum PriceDisplayMode {
  INCLUSIVE
  EXCLUSIVE
}

model Category {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  slug      String       @unique
  image     String?
  sortOrder Int          @default(0)
  status    EntityStatus @default(ACTIVE)
  // GST (Phase 13): category-level defaults inherited by products that don't
  // set their own. gstRateBps is basis points (1800 = 18.00%).
  defaultHsnCode    String?
  defaultGstRateBps Int?
  parentId  String?      @db.ObjectId
  parent    Category?    @relation("SubCategories", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children  Category[]   @relation("SubCategories")
  products  Product[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([status, sortOrder])
}

// Images are embedded in the product document (Mongo-idiomatic:
// they are always loaded and saved together with the product).
type ProductImage {
  url       String
  thumbUrl  String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)
}

model Product {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  categoryId  String         @db.ObjectId
  category    Category       @relation(fields: [categoryId], references: [id])
  name        String
  slug        String         @unique
  sku         String         @unique
  // Legacy free-text brand, retained during the Brand-master migration.
  brand       String?
  brandId     String?        @db.ObjectId
  brandRef    Brand?         @relation(fields: [brandId], references: [id])
  description String?
  specs       Json?
  price       Int // paise
  mrp         Int? // paise
  moq         Int?
  // GST (Phase 13): optional per-product override; null ⇒ inherit the
  // category default, then the SellerTaxProfile default. gstRateBps is basis
  // points (1800 = 18.00%). taxTreatment null ⇒ inherit the profile mode.
  hsnCode      String?
  gstRateBps   Int?
  taxTreatment TaxTreatment?
  stockStatus StockStatus    @default(IN_STOCK)
  status      EntityStatus   @default(ACTIVE)
  tags        String[]       @default([])
  images      ProductImage[]
  pageViews   PageView[]
  wishlistedBy WishlistItem[]
  cartItems   CartItem[]
  // Variants (opt-in per product). When hasVariants is false the product
  // behaves exactly as before: `price`/`mrp`/`stockStatus`/`sku` are authoritative
  // and there are no ProductVariant rows. When true, `price` is the denormalized
  // "from" (min active variant) for list/sort, and each ProductVariant carries
  // its own price/sku/stock. optionTypes is the embedded axis definition
  // (e.g. [{ name: "Capacity", values: ["10000mAh","20000mAh"] }]).
  hasVariants Boolean          @default(false)
  optionTypes Json?
  variants    ProductVariant[]
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([categoryId, status])
  @@index([deletedAt])
  @@index([brandId])
  // Hot storefront listing: filter {status, deletedAt} sorted by createdAt.
  @@index([status, deletedAt, createdAt])
}

model Customer {
  id           String          @id @default(auto()) @map("_id") @db.ObjectId
  businessName String
  contactName  String
  phone        String          @unique
  passwordHash String
  email        String?
  gstNumber    String?
  // GST (Phase 13): 2-digit state code parsed from a validated GSTIN, and the
  // explicit place of supply (billing state). GSTIN state wins for registered
  // buyers; unregistered buyers fall back to placeOfSupplyStateCode.
  gstStateCode           String?
  placeOfSupplyStateCode String?
  city         String?
  status       CustomerStatus  @default(PENDING)
  notes        String?
  accessGrants AccessGrant[]
  requests     AccessRequest[]
  sessions     Session[]
  pageViews    PageView[]
  wishlist     WishlistItem[]
  cartItems    CartItem[]
  orders       Order[]
  lastLoginAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([status])
}

model AccessGrant {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  customerId String    @db.ObjectId
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  approvedAt DateTime  @default(now())
  expiresAt  DateTime?
  revokedAt  DateTime?
  grantedBy  String

  @@index([customerId, expiresAt])
}

model AccessRequest {
  id         String        @id @default(auto()) @map("_id") @db.ObjectId
  customerId String        @db.ObjectId
  customer   Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status     RequestStatus @default(PENDING)
  reason     String?
  decidedAt  DateTime?
  createdAt  DateTime      @default(now())

  @@index([status, createdAt])
}

// An admin/staff user. Access is governed by the assigned Role's permissions.
model Admin {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  email        String    @unique
  passwordHash String
  totpSecret   String?
  name         String
  isActive     Boolean   @default(true)
  roleId       String?   @db.ObjectId
  role         Role?     @relation(fields: [roleId], references: [id])
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]

  @@index([roleId])
}

// A named set of permissions (RBAC). Permission keys are free-form strings from
// a central catalog (see src/lib/permissions.ts), so access is fully
// configurable. `isSystem` marks built-in roles (e.g. Owner) that cannot be
// deleted and always retain full access.
model Role {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  description String?
  permissions String[] @default([])
  isSystem    Boolean  @default(false)
  admins      Admin[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Session {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  tokenHash  String    @unique
  customerId String?   @db.ObjectId
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  adminId    String?   @db.ObjectId
  admin      Admin?    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?

  @@index([customerId])
  @@index([adminId])
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  actorType String
  actorId   String
  action    String
  entity    String
  entityId  String
  diff      Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}

model Notification {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  type      String
  payload   Json
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([readAt, createdAt])
}

// Web Push subscriptions (admin devices) — populated when an admin enables
// push in the PWA; consumed by src/server/notify/push.ts to send alerts.
model PushSubscription {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  endpoint  String   @unique
  p256dh    String
  auth      String
  adminId   String?  @db.ObjectId
  userAgent String?
  createdAt DateTime @default(now())

  @@index([adminId])
}

model PageView {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  customerId String?   @db.ObjectId
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  productId  String    @db.ObjectId
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())

  @@index([productId, createdAt])
  @@index([customerId, createdAt])
}

model Brand {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  name      String       @unique
  slug      String       @unique
  logo      String?
  status    EntityStatus @default(ACTIVE)
  sortOrder Int          @default(0)
  products  Product[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([status, sortOrder])
}

model WishlistItem {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId String   @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId  String   @db.ObjectId
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId  String?
  note       String?
  createdAt  DateTime @default(now())

  @@unique([customerId, productId])
  @@index([customerId, createdAt])
}

// A specific purchasable variant of a Product (e.g. "20000mAh · Black").
// Only present when the parent Product.hasVariants is true. Price is integer
// paise, gated exactly like Product.price.
model ProductVariant {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  productId    String       @db.ObjectId
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku          String       @unique
  // Chosen value per option axis, e.g. { "Capacity": "20000mAh", "Color": "Black" }.
  optionValues Json
  price        Int // paise
  mrp          Int? // paise
  moq          Int?
  // GST (Phase 13): per-variant override; null ⇒ inherit the parent product.
  hsnCode      String?
  gstRateBps   Int?
  taxTreatment TaxTreatment?
  stockStatus  StockStatus  @default(IN_STOCK)
  status       EntityStatus @default(ACTIVE)
  images       ProductImage[]
  isDefault    Boolean      @default(false)
  sortOrder    Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([productId, status])
}

// A line in an approved customer's cart. One row per (customer, product,
// variant). Quantity is validated server-side (>= MOQ, <= caps). Prices are
// NEVER stored here — they are computed server-side at placement from the
// gated DAL, so a client can't manipulate them.
model CartItem {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId String   @db.ObjectId
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId  String   @db.ObjectId
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId  String?  @db.ObjectId
  quantity   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([customerId, productId, variantId])
  @@index([customerId])
}

// A placed order (a purchase request — no payment collected). `items` is a
// server-computed snapshot (name/sku/brand/variant/qty/unitPricePaise/lineTotal)
// so later catalog changes don't alter the order. orderNumber is a random,
// non-enumerable public reference.
model Order {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber   String      @unique
  customerId    String      @db.ObjectId
  customer      Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status        OrderStatus @default(PLACED)
  items         Json
  subtotalPaise Int
  itemCount     Int
  note          String?
  adminNote     String?
  // GST (Phase 13): tax snapshot frozen at placement (rates change; a placed
  // order must not). Per-line tax lives inside `items`; these are the
  // order-level totals + supply context. All *Paise are integer paise.
  // gstEnabled=false at placement ⇒ these stay null and the order behaves
  // exactly as a pre-GST order (subtotalPaise is the total).
  taxApplied             Boolean     @default(false)
  supplyType             SupplyType?
  placeOfSupplyStateCode String?
  sellerStateCode        String?
  sellerGstin            String?
  totalTaxablePaise      Int?
  totalCgstPaise         Int?
  totalSgstPaise         Int?
  totalIgstPaise         Int?
  totalTaxPaise          Int?
  roundOffPaise          Int?
  grandTotalPaise        Int?
  // Group-by-(hsn,rate) summary rows for the invoice layout.
  hsnSummary             Json?
  placedAt      DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([customerId, placedAt])
  @@index([status, placedAt])
}

// ── Seller tax profile (Phase 13) ─────────────────────────────────────────
// A single settings document for the wholesaler's GST configuration. There is
// exactly one row (a fixed `key`); the service upserts it. When `gstEnabled`
// is false the whole GST feature is inert and the app behaves exactly as
// pre-GST (no tax figures anywhere), which is the safe default at launch.
model SellerTaxProfile {
  id                String           @id @default(auto()) @map("_id") @db.ObjectId
  key               String           @unique @default("default")
  gstEnabled        Boolean          @default(false)
  gstin             String?
  legalName         String?
  stateCode         String? // 2-digit place-of-supply origin
  priceEntryMode    TaxTreatment     @default(TAX_EXCLUSIVE)
  displayMode       PriceDisplayMode @default(EXCLUSIVE)
  roundingMode      RoundingMode     @default(LINE)
  defaultGstRateBps Int              @default(1800) // 18.00%
  defaultHsnCode    String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}
