# Database
# Local development (start with: ./scripts/local-mongo.sh start):
DATABASE_URL="mongodb://127.0.0.1:27018/memorydeals?replicaSet=rs0local&directConnection=true"
# Production (MongoDB Atlas — free M0 tier: https://www.mongodb.com/cloud/atlas):
# DATABASE_URL="mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/memorydeals?retryWrites=true&w=majority"

# Auth
AUTH_SECRET="generate-with: openssl rand -base64 32"

# Bot protection (Cloudflare Turnstile — free: https://www.cloudflare.com/products/turnstile/)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Image storage (Cloudflare R2 — S3 compatible)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="memorydeals-images"
R2_PUBLIC_URL=""

# Rate limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# Public site origin (used for metadataBase, sitemap, OG). No trailing slash.
NEXT_PUBLIC_SITE_URL="https://thememorydeals.com"

# Web Push (generate with: npx web-push generate-vapid-keys)
# The PUBLIC key must ALSO be exposed to the browser:
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_SUBJECT="mailto:hello@thememorydeals.com"

# Storefront WhatsApp enquire button (digits only, incl. country code)
NEXT_PUBLIC_WHATSAPP_NUMBER="919000000000"

# Secret guarding the daily expiry cron (GET /api/cron/expiry, header x-cron-secret)
CRON_SECRET=""

# Admin subdomain (production). When set, the admin console is served at this
# host and /admin/* on the main storefront domain redirects here. Leave unset
# to serve /admin on the main domain. Example: "admin.thememorydeals.com"
ADMIN_HOST=""
