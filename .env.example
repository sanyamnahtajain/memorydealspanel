# Database
# Local development (start with: ./scripts/local-mongo.sh start):
DATABASE_URL="mongodb://127.0.0.1:27018/memorydeals?replicaSet=rs0local&directConnection=true"
# Production (MongoDB Atlas — free M0 tier: https://www.mongodb.com/cloud/atlas):
# DATABASE_URL="mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/memorydeals?retryWrites=true&w=majority"

# Auth
AUTH_SECRET="generate-with: openssl rand -base64 32"

# Bot protection (Cloudflare Turnstile — free: https://www.cloudflare.com/products/turnstile/)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Image storage (Cloudflare R2 — S3 compatible)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="memorydeals-images"
R2_PUBLIC_URL=""

# Rate limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
